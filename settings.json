{
    "workbench.startupEditor": "none",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "git.autofetch": true,
    "redhat.telemetry.enabled": false,
    "explorer.confirmDelete": false,
    "workbench.browser.enableChatTools": true,
    "editor.semanticHighlighting.enabled": true,
    "vim.enableNeovim": false,
    "vim.startInInsertMode": true,
    "vim.useSystemClipboard": false,
    "vim.showcmd": false,
    "vim.hlsearch": false,
    "vim.incsearch": false,
    "vim.statusBarColorControl": false,
    "vim.leader": "",

    "vim.handleKeys": {
        "<C-a>": false,
        "<C-b>": false,
        "<C-c>": false,
        "<C-d>": false,
        "<C-e>": false,
        "<C-f>": false,
        "<C-h>": false,
        "<C-i>": false,
        "<C-j>": false,
        "<C-k>": false,
        "<C-l>": false,
        "<C-n>": false,
        "<C-o>": false,
        "<C-p>": false,
        "<C-q>": false,
        "<C-r>": false,
        "<C-s>": false,
        "<C-t>": false,
        "<C-u>": false,
        "<C-v>": false,
        "<C-w>": false,
        "<C-x>": false,
        "<C-y>": false,
        "<C-z>": false,
        "<C-]>": false,
        "<C-[>": false
    },
    "vim.normalModeKeyBindingsNonRecursive": [
        { "before": ["j"], "after": ["h"] },
        { "before": [";"], "after": ["l"] },
        { "before": ["k"], "after": ["k"] },
        { "before": ["l"], "after": ["j"] }
    ],
    "vim.visualModeKeyBindingsNonRecursive": [
        { "before": ["j"], "after": ["h"] },
        { "before": [";"], "after": ["l"] },
        { "before": ["k"], "after": ["k"] },
        { "before": ["l"], "after": ["j"] }
    ],
    "vim.insertModeKeyBindings": [
        // { "before": ["j"], "after": ["h"] },
        // { "before": [";"], "after": ["l"] },
        // { "before": ["k"], "after": ["k"] },
        // { "before": ["l"], "after": ["j"] }
    ],
    "workbench.colorTheme": "Tokyo City No Italic",
    "workbench.colorCustomizations": {
        // Example: make the sidebar foreground text brighter
        "[Tokyo City No Italic]": {
            // General UI contrast: makes borders and separators more visible
            "contrastBorder": "#2b2d3f",
            //"widget.border": "#0026ff",

            // Activity Bar (leftmost icons bar) background
            "activityBar.background": "#23252d",
            // Sidebar (file explorer) background and inactive file names
            "sideBar.background": "#181f24",
            // "list.inactiveForeground": "#a9b1d6", // Brighter gray for dimmed file names

            "panelTitle.activeForeground": "#a4c1ff",
            "panelTitle.inactiveForeground": "#959bc2",
            
            // Status Bar (bottom bar)
            "statusBar.background": "#20212e",
            "statusBar.foreground": "#93a3c4", // Brighter text color
            "statusBar.debuggingBackground": "#849d38",

            // Tabs Background
            "editorGroupHeader.tabsBackground": "#171d23",

            // Background color of the right-click menu itself
            "menu.background": "#581e35", 
            // Text color of the menu items
            "menu.foreground": "#c4e8e3",
            // Color when hovering over an item (the active selection)
            "menu.selectionBackground": "#595b8e", 
            // Text color when hovering over an item
            "menu.selectionForeground": "#ffffff",
            
            "terminal.foreground": "#70abcd",


            // Background color of text that is actively selected/highlighted by the user
            "editor.selectionBackground": "#b08bea3d" 
        }
    },
    "editor.tokenColorCustomizations": {
        "[Tokyo City No Italic]": {
            "textMateRules": [
                {
                    "scope": ["comment", "comment.block.documentation"],
                    "settings": { "foreground": "#8B95A5", "fontStyle": "italic" }
                },
                {
                    "scope": ["keyword", "keyword.control", "storage.type", "keyword.operator"],
                    "settings": { "foreground": "#A5B4FC" }
                },
                {
                    "scope": ["variable", "variable.other", "identifier"],
                    "settings": { "foreground": "#C8D0DC" }
                },
                {
                    "scope": ["variable.parameter"],
                    "settings": { "foreground": "#DEC98A" }
                },
                {
                    "scope": ["entity.name.function", "support.function", "meta.function-call"],
                    "settings": { "foreground": "#8BB8E0" }
                },
                {
                    "scope": ["entity.name.type", "support.type", "storage.type", "entity.name.class", "support.class"],
                    "settings": { "foreground": "#D4C08A" }
                },
                {
                    "scope": ["string", "string.quoted", "constant.character", "constant.other"],
                    "settings": { "foreground": "#7CCAAA" }
                },
                {
                    "scope": ["constant.numeric", "constant.language", "constant.other.boolean"],
                    "settings": { "foreground": "#D998B8" }
                },
                {
                    "scope": ["support.constant", "constant.character.escape"],
                    "settings": { "foreground": "#6EC8D0" }
                },
                {
                    "scope": ["entity.name.tag", "support.class.component", "meta.tag"],
                    "settings": { "foreground": "#D89090" }
                },
                {
                    "scope": ["entity.other.attribute-name", "support.type.property-name"],
                    "settings": { "foreground": "#D8A878" }
                },
                {
                    "scope": ["punctuation", "meta.brace"],
                    "settings": { "foreground": "#8895A5" }
                },
                {
                    "scope": ["meta.selector", "entity.name.scss", "entity.other.inherited-class"],
                    "settings": { "foreground": "#B8B0D8" }
                },
                {
                    "scope": ["support.function.magic", "support.function.magic.python"],
                    "settings": { "foreground": "#78B8D8" }
                },
                {
                    "scope": ["entity.name.function.decorator", "meta.decorator"],
                    "settings": { "foreground": "#D8A878" }
                }
            ]
        }
    },
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "variable": "#C8D0DC",
            "parameter": "#DEC98A",
            "function": "#8BB8E0",
            "method": "#98C0E0",
            "property": "#B8B0D8",
            "class": "#D4C08A",
            "type": "#DEC98A",
            "namespace": "#D4C08A",
            "string": "#7CCAAA",
            "number": "#D998B8",
            "boolean": "#D998B8",
            "operator": "#A5B4FC",
            "decorator": "#D8A878",
            "builtin": "#78B8D8",
            "enumMember": "#6EC8D0"
        }
    },
    "window.titleBarStyle": "custom",
    "git.enableSmartCommit": true,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "code-runner.executorMap": {

        "javascript": "node",
        "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
        "c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "zig": "zig run",
        "cpp": "cd $dir && g++ $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "php": "php",
        "python": "python3 -u",
        "perl": "perl",
        "perl6": "perl6",
        "ruby": "ruby",
        "go": "go run",
        "lua": "lua",
        "groovy": "groovy",
        "powershell": "powershell -ExecutionPolicy ByPass -File",
        "bat": "cmd /c",
        "shellscript": "bash",
        "fsharp": "fsi",
        "csharp": "scriptcs",
        "vbscript": "cscript //Nologo",
        "typescript": "ts-node",
        "coffeescript": "coffee",
        "scala": "scala",
        "swift": "swift",
        "julia": "julia",
        "crystal": "crystal",
        "ocaml": "ocaml",
        "r": "Rscript",
        "applescript": "osascript",
        "clojure": "lein exec",
        "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
        "rust": "cd $dir && rustc $fileName && $dir$fileNameWithoutExt",
        "racket": "racket",
        "scheme": "csi -script",
        "ahk": "autohotkey",
        "autoit": "autoit3",
        "dart": "dart",
        "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
        "haskell": "runghc",
        "nim": "nim compile --verbosity:0 --hints:off --run",
        "lisp": "sbcl --script",
        "kit": "kitc --run",
        "v": "v run",
        "sass": "sass --style expanded",
        "scss": "scss --style expanded",
        "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",
        "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "sml": "cd $dir && sml $fileName",
        "mojo": "mojo run",
        "erlang": "escript",
        "spwn": "spwn build",
        "pkl": "cd $dir && pkl eval -f yaml $fileName -o $fileNameWithoutExt.yaml",
        "gleam": "gleam run -m $fileNameWithoutExt"
    },
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "c": false
    },
    "code-runner.executorMapByGlob": {
        "pom.xml": "cd $dir && mvn clean package"
    },
    "code-runner.executorMapByFileExtension": {

        ".vb": "cd $dir && vbc /nologo $fileName && $dir$fileNameWithoutExt",
        ".vbs": "cscript //Nologo",
        ".scala": "scala",
        ".jl": "julia",
        ".cr": "crystal",
        ".ml": "ocaml",
        ".zig": "zig run",
        ".exs": "elixir",
        ".hx": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
        ".rkt": "racket",
        ".scm": "csi -script",
        ".ahk": "autohotkey",
        ".au3": "autoit3",
        ".kt": "cd $dir && kotlinc $fileName -include-runtime -d $fileNameWithoutExt.jar && java -jar $fileNameWithoutExt.jar",
        ".kts": "kotlinc -script",
        ".dart": "dart",
        ".pas": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        ".pp": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        ".d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
        ".hs": "runhaskell",
        ".nim": "nim compile --verbosity:0 --hints:off --run",
        ".csproj": "dotnet run --project",
        ".fsproj": "dotnet run --project",
        ".lisp": "sbcl --script",
        ".kit": "kitc --run",
        ".v": "v run",
        ".vsh": "v run",
        ".sass": "sass --style expanded",
        ".cu": "cd $dir && nvcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        ".ring": "ring",
        ".sml": "cd $dir && sml $fileName",
        ".mojo": "mojo run",
        ".erl": "escript",
        ".spwn": "spwn build",
        ".pkl": "cd $dir && pkl eval -f yaml $fileName -o $fileNameWithoutExt.yaml",
        ".gleam": "gleam run -m $fileNameWithoutExt"
    },
    "vscord.app.name": "Visual Studio Code",
    "vscord.status.idle.enabled": false,
    "vscord.status.problems.enabled": false,
    "vscord.status.state.debugging.enabled": false,
    "vscord.behaviour.suppressRpcCouldNotConnect": true,
    "vscord.status.state.text.editing": "Working on {file_name}{file_extension}",
    "vscord.behaviour.suppressNotifications": true,
    "workbench.editor.empty.hint": "hidden",
    "vscord.status.idle.check": false
}